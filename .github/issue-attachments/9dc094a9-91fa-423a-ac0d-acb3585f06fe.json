{
  "openapi": "3.0.0",
  "info": {
    "title": "User Management System API",
    "description": "API for managing users",
    "version": "1.0.0",
    "contact": {
      "name": "Support Team"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Development server"
    }
  ],
  "paths": {
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "description": "Retrieve a list of users with optional filtering by search term, status, or role. Can also export as CSV format.",
        "operationId": "getAllUsers",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search term to filter users by userId, email, or first name and last name",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "Filter users by status (active, blocked, pending)",
            "schema": {
              "type": "string",
              "enum": ["active", "blocked", "pending"]
            }
          },
          {
            "name": "role",
            "in": "query",
            "description": "Filter users by role ID",
            "schema": {
              "type": "integer"
            }
          },
          {
            "name": "format",
            "in": "query",
            "description": "Export format (json or csv)",
            "schema": {
              "type": "string",
              "enum": ["json", "csv"],
              "default": "json"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/User"
                  }
                }
              },
              "text/csv": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "500": {
            "description": "Failed to fetch users"
          }
        }
      },
      "post": {
        "summary": "Create a new user",
        "description": "Create a new user with the provided credentials and details",
        "operationId": "createNewUser",
        "tags": ["Users"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateUserRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "500": {
            "description": "Failed to create user"
          }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Get user details",
        "description": "Retrieve a specific user's details including their roles and entities",
        "operationId": "getUserDetails",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserWithRoles"
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Failed to fetch user"
          }
        }
      },
      "put": {
        "summary": "Update user",
        "description": "Update a user's email, full name, status, or password",
        "operationId": "updateUser",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateUserRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                }
              }
            }
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Failed to update user"
          }
        }
      },
      "delete": {
        "summary": "Delete user",
        "description": "Delete a user from the system",
        "operationId": "deleteUser",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted successfully"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Failed to delete user"
          }
        }
      }
    },
    "/api/users/{id}/entity-access": {
      "put": {
        "summary": "Configure user access",
        "description": "Configure user's entity access",
        "operationId": "configureUserEntityAccess",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "entitiesAccessMode": {
                    "type": "string",
                    "enum": ["none", "all", "specific"],
                    "description": "Entity access mode"
                  },
                  "selectedEntities": {
                    "type": "array",
                    "items": {
                      "type": "integer"
                    },
                    "description": "Array of entity IDs when using specific access mode"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Access configured successfully"
          },
          "404": {
            "description": "User not found"
          },
          "500": {
            "description": "Failed to configure access"
          }
        }
      }
    },
    "/api/users/{id}/toggle-status": {
      "post": {
        "summary": "Toggle user status",
        "description": "Toggle between active and blocked status",
        "operationId": "toggleUserStatus",
        "tags": ["Users"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "User ID",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Status toggled successfully"
          },
          "500": {
            "description": "Failed to toggle status"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "User ID"
          },
          "userId": {
            "type": "string",
            "description": "User ID"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "User email address"
          },
          "firstName": {
            "type": "string",
            "description": "User's first name"
          },
          "lastName": {
            "type": "string",
            "description": "User's last name"
          },
          "status": {
            "type": "string",
            "enum": ["active", "blocked", "pending"],
            "description": "User status"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Last update timestamp"
          }
        }
      },
      "UserWithRoles": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "userId": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Role"
            }
          },
          "entities": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "CreateUserRequest": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "minLength": 3
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["active", "blocked", "pending"],
            "default": "active"
          }
        },
        "required": ["userId", "password", "email", "firstName", "lastName"]
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["active", "blocked", "pending"]
          },
          "password": {
            "type": "string"
          }
        }
      },
      "Role": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Users",
      "description": "User management operations"
    }
  ]
}